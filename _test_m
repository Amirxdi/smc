import asyncio
import ccxt.async_support as ccxt

async def test():
    configs = [
        ('bybit', ccxt.bybit, {'enableRateLimit': True}, {'defaultType': 'swap', 'defaultSubType': 'linear'}),
        ('okx', ccxt.okx, {'enableRateLimit': True}, {'defaultType': 'swap'}),
        ('mexc', ccxt.mexc, {'enableRateLimit': True}, {'defaultType': 'swap'}),
        ('gate', ccxt.gateio, {'enableRateLimit': True}, {'defaultType': 'swap'}),
    ]
    
    for name, cls, params, options in configs:
        try:
            params['options'] = options
            ex = cls(**params)
            await ex.load_markets()
            perps = []
            for s, m in ex.markets.items():
                if m.get('contract') and s.endswith('/USDT'):
                    perps.append(s)
            count = len(perps)
            sample = perps[0] if perps else 'none'
            print(f"{name}: {count} USDT perpetuals (e.g. {sample})")
            await ex.close()
        except Exception as e:
            print(f"{name}: FAIL - {e}")

asyncio.run(test())